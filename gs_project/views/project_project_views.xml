<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_inherit_gs_project" model="ir.ui.view">
        <field name="name">project.project.form.inherit.gs.project</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- Add button to header -->
            <xpath expr="//header" position="inside">
                <button name="action_generate_planning_slots"
                        string="Generate Planning"
                        type="object"
                        class="oe_highlight"
                        groups="project.group_project_manager"/>
            </xpath>

            <!-- Add Employees tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Planning Resources" name="planning_employees" invisible="1">
                    <separator string="Assigned Employees for Planning"/>
                    <field name="employee_ids" widget="many2many_tags"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
