<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_form_inherit_gs" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.gs</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_email']" position="after">
                <field name="cin" required="0"
                       placeholder="ex. G913831"/>
                <field name="cnss" required="0"
                       placeholder="ex. 123456789"/>
                <field name="rest_weekday_ids" widget="many2many_tags"
                       options="{'no_create': True}"
                       placeholder="ex. Samedi, Dimanche"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_employee_list_inherit_gs" model="ir.ui.view">
        <field name="name">hr.employee.list.inherit.gs</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="cin" optional="show"/>
                <field name="cnss" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_employee_search_inherit_gs" model="ir.ui.view">
        <field name="name">hr.employee.search.inherit.gs</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="cin" string="CIN"/>
                <field name="cnss" string="N° CNSS"/>
            </xpath>
        </field>
    </record>

</odoo>
