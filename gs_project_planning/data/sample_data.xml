    <!-- =================================================================
         PROJETS DE DÉMO (5 scénarios)
         Légende des dates (T = aujourd'hui) :
            P1 [T,      T+14]   → projet en cours (Carrefour Maarif)
            P2 [T,      T+14]   → projet en cours parallèle (Marjane Hay Riad)
            P3 [T+20,   T+45]   → projet futur long (Twin Center)
            P4 [T-30,   T-10]   → projet passé (Stade Mohammed V)
            P5 [T+50,   T+80]   → projet futur (Chantier Sidi Maarouf)
         ================================================================= -->

    <!-- ====================== P1 : Carrefour Maarif ====================== -->
    <record id="demo_project_p1_carrefour_maarif" model="project.project">
        <field name="name">[P1] Sécurité — Carrefour Maarif</field>
        <field name="date_start" eval="DateTime.now().strftime('%Y-%m-%d')"/>
        <field name="date" eval="(DateTime.now() + relativedelta(days=14)).strftime('%Y-%m-%d')"/>
        <field name="user_id" ref="base.user_admin"/>
        <field name="allow_timesheets" eval="True"/>
        <field name="daily_hour_limit">40.0</field>
        <field name="allowed_employee_ids" eval="[(6, 0, [
            ref('demo_emp_sec_ahmed'),
            ref('demo_emp_sec_yassine'),
            ref('demo_emp_sec_aziz'),
            ref('demo_emp_cln_najat'),
            ref('demo_emp_mng_brahim'),
        ])]"/>
    </record>

    <record id="demo_p1_line_ahmed" model="gs.project.planning.line">
        <field name="project_id" ref="demo_project_p1_carrefour_maarif"/>
        <field name="employee_id" ref="demo_emp_sec_ahmed"/>
